<Window x:Class="VideoSubtitleApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎬 LexiVerse Video Captioner"
        Width="1280" Height="780"
        MinWidth="900" MinHeight="600"
        Background="{StaticResource BrBgDeep}"
        Foreground="{StaticResource BrTextPrimary}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- タイムコード表示用コンバーター (分:秒) -->
        <converter:TimeSpanToStringConverter x:Key="TsConverter"
            xmlns:converter="clr-namespace:VideoSubtitleApp.Converters"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- タイトルバー -->
            <RowDefinition Height="48"/>
            <!-- メインコンテンツ -->
            <RowDefinition Height="*"/>
            <!-- ステータスバー -->
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- タイトルバー -->
        <Border Grid.Row="0" Background="{StaticResource BrBgPanel}"
                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BrBorder}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ロゴ -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎬" FontSize="22" Margin="0,0,8,0"/>
                    <TextBlock Text="LexiVerse Video Captioner"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource BrTextPrimary}"/>
                    <Border Background="{StaticResource BrAccent}"
                            CornerRadius="3" Padding="5,1" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="Preview" FontSize="10" Foreground="White"/>
                    </Border>
                </StackPanel>
                
                <!-- 設定 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Column="1">
                    <ComboBox x:Name="ComboLanguageSettings" Margin="5" Style="{StaticResource HeaderComboBoxStyle}"></ComboBox>
                    <ComboBox x:Name="ComboModelSettings" Margin="5" Style="{StaticResource HeaderComboBoxStyle}"></ComboBox>
                </StackPanel>

                <!-- ファイル操作ボタン群 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            x:Name="ToolbarButtons">
                    <Button x:Name="BtnOpenVideo"
                            Style="{StaticResource SecondaryButton}"
                            Content="📂 動画を開く" Margin="0,0,8,0"
                            Click="BtnOpenVideo_Click"/>
                    <Button x:Name="BtnTranscribe"
                            Style="{StaticResource PrimaryButton}"
                            Content="🎙 字幕を生成" Margin="0,0,8,0"
                            IsEnabled="False"
                            Click="BtnTranscribe_Click"/>
                    <Button x:Name="BtnExportSrt"
                            Style="{StaticResource SecondaryButton}"
                            Content="💾 SRT 保存" Margin="0,0,8,0"
                            IsEnabled="False"
                            Click="BtnExportSrt_Click"/>
                    <Button x:Name="BtnClearSubtitles"
                            Style="{StaticResource DangerButton}"
                            Content="🗑 クリア"
                            IsEnabled="False"
                            Click="BtnClearSubtitles_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             メインコンテンツ (左: 動画プレーヤー / 右: 字幕リスト)
        ══════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 動画プレーヤー側 -->
                <ColumnDefinition Width="3*" MinWidth="400"/>
                <!-- スプリッター -->
                <ColumnDefinition Width="4"/>
                <!-- 字幕パネル側 -->
                <ColumnDefinition Width="*" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- ────────────────────────────────
                 左: 動画プレーヤー + コントロール
            ──────────────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <!-- オーバーレイ字幕 -->
                    <RowDefinition Height="Auto"/>
                    <!-- シークバー -->
                    <RowDefinition Height="Auto"/>
                    <!-- 再生コントロール -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 動画描画領域 -->
                <Border Grid.Row="0" Background="Black">
                    <MediaElement x:Name="VideoPlayer"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Stop"
                                  Stretch="Uniform"
                                  MediaOpened="VideoPlayer_MediaOpened"
                                  MediaEnded="VideoPlayer_MediaEnded"
                                  MediaFailed="VideoPlayer_MediaFailed"/>
                </Border>

                <!-- ドロップ先ガイド（動画未ロード時） -->
                <Border Grid.Row="0" x:Name="DropGuide"
                        Background="#10FFFFFF" IsHitTestVisible="False">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🎬" FontSize="48" HorizontalAlignment="Center"
                                   Foreground="{StaticResource BrTextSecondary}"/>
                        <TextBlock Text="動画ファイルをドロップ"
                                   FontSize="16" Margin="0,12,0,4"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="または「動画を開く」ボタンをクリック"
                                   FontSize="12"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- リアルタイム字幕オーバーレイ -->
                <Border Grid.Row="1" Background="#CC000000"
                        Padding="16,8" x:Name="SubtitleOverlay" Visibility="Collapsed">
                    <TextBlock x:Name="TxtSubtitleOverlay"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource BrHighlight}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Border>

                <!-- シークバー -->
                <Grid Grid.Row="2" Margin="12,6,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="SeekBar"
                            Grid.Column="0"
                            Minimum="0" Maximum="100" Value="0"
                            IsEnabled="False"
                            Thumb.DragStarted="SeekBar_DragStarted"
                            Thumb.DragCompleted="SeekBar_DragCompleted"
                            ValueChanged="SeekBar_ValueChanged"
                            Foreground="{StaticResource BrAccent}"/>
                    <TextBlock x:Name="TxtTimeCode"
                               Grid.Column="1"
                               Text="00:00 / 00:00"
                               Foreground="{StaticResource BrTextSecondary}"
                               FontSize="11" Margin="10,0,0,0"
                               VerticalAlignment="Center" FontFamily="Consolas"/>
                </Grid>

                <!-- 再生コントロール -->
                <Border Grid.Row="3" Background="{StaticResource BrBgPanel}"
                        BorderThickness="0,1,0,0" BorderBrush="{StaticResource BrBorder}"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnRewind"
                                Style="{StaticResource SecondaryButton}"
                                Content="⏮ -10s" IsEnabled="False"
                                Click="BtnRewind_Click" Margin="0,0,6,0"/>
                        <Button x:Name="BtnPlayPause"
                                Style="{StaticResource PrimaryButton}"
                                Content="▶ 再生" Width="120" IsEnabled="False"
                                Click="BtnPlayPause_Click" Margin="0,0,6,0"/>
                        <Button x:Name="BtnForward"
                                Style="{StaticResource SecondaryButton}"
                                Content="+10s ⏭" IsEnabled="False"
                                Click="BtnForward_Click" Margin="0,0,12,0"/>
                        <!-- 音量 -->
                        <TextBlock Text="🔊" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{StaticResource BrTextSecondary}"/>
                        <Slider x:Name="VolumeSlider"
                                Minimum="0" Maximum="1" Value="0.8"
                                Width="80" VerticalAlignment="Center"
                                ValueChanged="VolumeSlider_ValueChanged"
                                Foreground="{StaticResource BrAccent}"/>
                        <!-- 速度 -->
                        <TextBlock Text="速度:" Margin="12,0,6,0" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrTextSecondary}" FontSize="12"/>
                        <ComboBox x:Name="SpeedCombo" Width="70" VerticalAlignment="Center"
                                  SelectionChanged="SpeedCombo_SelectionChanged"
                                  Background="{StaticResource BrBgCard}"
                                  Foreground="{StaticResource BrTextPrimary}"
                                  BorderBrush="{StaticResource BrBorder}">
                            <ComboBoxItem>0.5x</ComboBoxItem>
                            <ComboBoxItem>0.75x</ComboBoxItem>
                            <ComboBoxItem IsSelected="True">1.0x</ComboBoxItem>
                            <ComboBoxItem>1.25x</ComboBoxItem>
                            <ComboBoxItem>1.5x</ComboBoxItem>
                            <ComboBoxItem>2.0x</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- スプリッター -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BrBorder}"
                          ShowsPreview="True"/>

            <!-- ────────────────────────────────
                 右: 字幕パネル
            ──────────────────────────────── -->
            <Grid Grid.Column="2" Background="{StaticResource BrBgPanel}">
                <Grid.RowDefinitions>
                    <!-- ヘッダー -->
                    <RowDefinition Height="40"/>
                    <!-- フィルター -->
                    <RowDefinition Height="40"/>
                    <!-- リスト -->
                    <RowDefinition Height="*"/>
                    <!-- 編集エリア -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ヘッダー -->
                <Border Grid.Row="0"
                        BorderThickness="0,0,0,1" BorderBrush="{StaticResource BrBorder}"
                        Padding="12,0">
                    <Grid>
                        <TextBlock Text="📄 字幕リスト"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrTextPrimary}"/>
                        <TextBlock x:Name="TxtSubtitleCount"
                                   Text="0 件"
                                   FontSize="11" HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrTextSecondary}"/>
                    </Grid>
                </Border>

                <!-- 検索フィルター -->
                <Border Grid.Row="1"
                        BorderThickness="0,0,0,1" BorderBrush="{StaticResource BrBorder}"
                        Padding="8,6">
                    <TextBox x:Name="TxtSearch"
                             Background="{StaticResource BrBgCard}"
                             Foreground="{StaticResource BrTextPrimary}"
                             BorderBrush="{StaticResource BrBorder}"
                             BorderThickness="1"
                             Padding="8,4"
                             FontSize="12"
                             TextChanged="TxtSearch_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Resources>
                                    <VisualBrush x:Key="CueBannerBrush" AlignmentX="Left"
                                                 AlignmentY="Center" Stretch="None">
                                        <VisualBrush.Visual>
                                            <Label Content="🔍 テキストで絞り込み..."
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   FontSize="11"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background"
                                                Value="{StaticResource CueBannerBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <!-- 字幕リスト -->
                <ListBox x:Name="SubtitleList"
                         Grid.Row="2"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource SubtitleListItem}"
                         SelectionChanged="SubtitleList_SelectionChanged"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <!-- タイムコード行 -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Border Background="{StaticResource BrBgDeep}"
                                            CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Index}"
                                                   FontSize="9"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock FontFamily="Consolas" FontSize="10"
                                               Foreground="{StaticResource BrAccent}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} → {1}">
                                                <Binding Path="StartTime"
                                                         Converter="{StaticResource TsConverter}"/>
                                                <Binding Path="EndTime"
                                                         Converter="{StaticResource TsConverter}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                <!-- 字幕テキスト行 -->
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Text}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource BrTextPrimary}"
                                           FontSize="12" Margin="0,3,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 字幕編集エリア -->
                <Border Grid.Row="3"
                        Background="{StaticResource BrBgCard}"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource BrBorder}"
                        Padding="8">
                    <StackPanel>
                        <TextBlock Text="✏ 選択した字幕を編集"
                                   FontSize="11"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtEditSubtitle"
                                 Background="{StaticResource BrBgPanel}"
                                 Foreground="{StaticResource BrTextPrimary}"
                                 BorderBrush="{StaticResource BrBorder}"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 FontSize="13"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Height="60"
                                 IsEnabled="False"
                                 TextChanged="TxtEditSubtitle_TextChanged"/>
                        <Button x:Name="BtnApplyEdit"
                                Style="{StaticResource PrimaryButton}"
                                Content="✔ 変更を適用"
                                Margin="0,6,0,0"
                                IsEnabled="False"
                                HorizontalAlignment="Right"
                                Click="BtnApplyEdit_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════
             ステータスバー
        ══════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource BrBgPanel}"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource BrBorder}"
                Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ステータスメッセージ -->
                <TextBlock x:Name="TxtStatus"
                           Grid.Column="0"
                           Text="動画ファイルを開いてください"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource BrTextSecondary}"
                           FontSize="11"/>

                <!-- 進捗バー -->
                <ProgressBar x:Name="ProgressBar"
                             Grid.Column="1"
                             Width="160" Height="4"
                             Minimum="0" Maximum="100"
                             Value="0"
                             Visibility="Collapsed"
                             Margin="12,0"
                             Foreground="{StaticResource BrAccent}"
                             Background="{StaticResource BrBgCard}"/>

                <!-- 動画ファイル名 -->
                <TextBlock x:Name="TxtFileName"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource BrTextSecondary}"
                           FontSize="11"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             処理中オーバーレイ
        ══════════════════════════════════════════ -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="3"
              Background="#C0000000" Visibility="Collapsed">
            <Border Background="{StaticResource BrBgCard}"
                    CornerRadius="12" Padding="32,24"
                    Width="360"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="TxtLoadingTitle"
                               Text="🎙 字幕を生成中..."
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource BrTextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <ProgressBar x:Name="LoadingProgress"
                                 Height="6" Minimum="0" Maximum="100" Value="0"
                                 Foreground="{StaticResource BrAccent}"
                                 Background="{StaticResource BrBorder}"
                                 Margin="0,0,0,12"/>
                    <TextBlock x:Name="TxtLoadingDetail"
                               Text="準備中..."
                               FontSize="12"
                               Foreground="{StaticResource BrTextSecondary}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,16"/>
                    <Button x:Name="BtnCancelTranscription"
                            Style="{StaticResource DangerButton}"
                            Content="⏹ キャンセル"
                            HorizontalAlignment="Center"
                            Click="BtnCancelTranscription_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
