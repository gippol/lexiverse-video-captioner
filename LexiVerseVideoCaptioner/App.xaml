<Application x:Class="LexiVerseVideoCaptioner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml"
             xmlns:local="clr-namespace:LexiVerseVideoCaptioner">
    <Application.Resources>

        <!-- ===== カラーパレット ===== -->
        <Color x:Key="BgDeep">#0D0F14</Color>
        <Color x:Key="BgPanel">#161920</Color>
        <Color x:Key="BgCard">#1E2230</Color>
        <Color x:Key="Accent">#5B8AF0</Color>
        <Color x:Key="AccentHover">#7BA3FF</Color>
        <Color x:Key="Success">#3ECF8E</Color>
        <Color x:Key="Warning">#F5A623</Color>
        <Color x:Key="Danger">#E05252</Color>
        <Color x:Key="TextPrimary">#E8EAF0</Color>
        <Color x:Key="TextSecondary">#7A8299</Color>
        <Color x:Key="Border">#2A2F42</Color>
        <Color x:Key="SubtitleHighlight">#F5E642</Color>

        <SolidColorBrush x:Key="BrBgDeep"       Color="{StaticResource BgDeep}"/>
        <SolidColorBrush x:Key="BrBgPanel"      Color="{StaticResource BgPanel}"/>
        <SolidColorBrush x:Key="BrBgCard"       Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BrAccent"       Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="BrAccentHover"  Color="{StaticResource AccentHover}"/>
        <SolidColorBrush x:Key="BrSuccess"      Color="{StaticResource Success}"/>
        <SolidColorBrush x:Key="BrWarning"      Color="{StaticResource Warning}"/>
        <SolidColorBrush x:Key="BrDanger"       Color="{StaticResource Danger}"/>
        <SolidColorBrush x:Key="BrTextPrimary"  Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="BrTextSecondary" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BrBorder"       Color="{StaticResource Border}"/>
        <SolidColorBrush x:Key="BrHighlight"    Color="{StaticResource SubtitleHighlight}"/>

        <!-- ===== ボタン スタイル ===== -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource BrAccent}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrAccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource BrBgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrBorder}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource BrDanger}"/>
        </Style>

        <!-- ===== スクロールバー スタイル（シンプル化） ===== -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width"      Value="6"/>
        </Style>

        <!-- ===== ListBoxItem スタイル ===== -->
        <Style x:Key="SubtitleListItem" TargetType="ListBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="Padding"     Value="8,6"/>
            <Setter Property="Margin"      Value="0,1"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252A3A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E2D50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Combobox -->
        <Style x:Key="HeaderComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,6,0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- メインボーダー：左側にアクセントライン -->
                            <Border x:Name="MainBorder"
                            Background="{StaticResource BrBgCard}"
                            BorderBrush="{StaticResource BrBorder}"
                            BorderThickness="1"
                            CornerRadius="5"
                            SnapsToDevicePixels="True">

                                <!-- 左アクセントライン -->
                                <Border x:Name="AccentBar"
                                Background="{StaticResource BrAccent}"
                                Width="3"
                                CornerRadius="5,0,0,5"
                                HorizontalAlignment="Left"
                                Opacity="0"/>

                            </Border>

                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>

                                <!-- 選択アイテム表示 -->
                                <ContentPresenter
                                    x:Name="ContentSite"
                                    Grid.Column="0"
                                    IsHitTestVisible="False"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                    Margin="10,0,2,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"/>

                                <!-- 編集可能テキストボックス（IsEditable用） -->
                                <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Style="{x:Null}"
                                     Background="Transparent"
                                     Foreground="{StaticResource BrTextPrimary}"
                                     BorderThickness="0"
                                     Margin="10,0,2,0"
                                     VerticalAlignment="Center"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Focusable="True"/>

                                <!-- ドロップダウン矢印ボタン -->
                                <ToggleButton
                                    x:Name="ToggleButton"
                                    Grid.Column="1"
                                    Focusable="False"
                                    IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                                RelativeSource={RelativeSource TemplatedParent}}"
                                    ClickMode="Press"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Stretch">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <!-- カスタム矢印（Path） -->
                                                <Path x:Name="Arrow"
                                              Data="M 0 0 L 4 4 L 8 0"
                                              Stroke="{StaticResource BrTextSecondary}"
                                              StrokeThickness="1.5"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform x:Name="ArrowRotation" Angle="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation
                                                            Storyboard.TargetName="ArrowRotation"
                                                            Storyboard.TargetProperty="Angle"
                                                            To="180"
                                                            Duration="0:0:0.2">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation
                                                            Storyboard.TargetName="ArrowRotation"
                                                            Storyboard.TargetProperty="Angle"
                                                            To="0"
                                                            Duration="0:0:0.2">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                            </Grid>

                            <!-- ドロップダウンポップアップ -->
                            <Popup
                                x:Name="Popup"
                                Placement="Bottom"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                AllowsTransparency="True"
                                Focusable="False"
                                PopupAnimation="Fade">
                                <Grid x:Name="DropDown"
                                  SnapsToDevicePixels="True"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">

                                    <Border x:Name="DropDownBorder"
                                    Background="{StaticResource BrBgPanel}"
                                    BorderBrush="{StaticResource BrAccent}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Margin="0,3,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect
                                        Color="#000000"
                                        Direction="270"
                                        ShadowDepth="4"
                                        BlurRadius="12"
                                        Opacity="0.35"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="4,4" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>

                        <!-- トリガー -->
                        <ControlTemplate.Triggers>

                            <!-- ホバー時 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder"
                                Property="BorderBrush"
                                Value="{StaticResource BrAccent}"/>
                                <Setter TargetName="AccentBar"
                                Property="Opacity"
                                Value="1"/>
                            </Trigger>

                            <!-- フォーカス時 -->
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder"
                                Property="BorderBrush"
                                Value="{StaticResource BrAccent}"/>
                                <Setter TargetName="AccentBar"
                                Property="Opacity"
                                Value="1"/>
                            </Trigger>

                            <!-- ドロップダウンオープン時 -->
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder"
                                Property="CornerRadius"
                                Value="5,5,0,0"/>
                                <Setter TargetName="AccentBar"
                                Property="Opacity"
                                Value="1"/>
                            </Trigger>

                            <!-- 無効時 -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MainBorder"
                                Property="Opacity"
                                Value="0.4"/>
                                <Setter Property="Foreground"
                                Value="{StaticResource BrTextSecondary}"/>
                            </Trigger>

                            <!-- 編集可能モード -->
                            <Trigger Property="IsEditable" Value="True">
                                <Setter Property="IsTabStop" Value="False"/>
                                <Setter TargetName="PART_EditableTextBox"
                                Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite"
                                Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
